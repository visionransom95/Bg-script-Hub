rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /files/{fileId} {
      allow read: if true; // Allow public listing if needed? Or restrict to signed in?
      // For this specific app, keep it tight.
      allow write: if false; // Only admin SDK can write
    }
  }
}
