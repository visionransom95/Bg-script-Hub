# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Vercel Deployment Configuration
# Vercel sets VERCEL=true automatically, but you can set it here for local testing.
VERCEL="true"

# Vercel Blob Storage - Required for Vercel uploads if not using Firebase or Drive.
# Get yours from Vercel Project Settings > Storage (Create a Blob store)
BLOB_READ_WRITE_TOKEN=""

# Encryption Secret - Required for encrypted uploads on Vercel
# Must be 32 characters or will be padded/sliced automatically.
ENCRYPTION_SECRET=""

# Local storage directory path (optional)
# On Vercel, this defaults to /tmp/uploads
STORAGE_DIR=""

# Admin password for file deletion
ADMIN_PASSWORD=""

# Google Drive Storage - Optional
# Set GOOGLE_DRIVE_CREDENTIALS to the JSON object of your service account
GOOGLE_DRIVE_CREDENTIALS=""
# Set GOOGLE_DRIVE_FOLDER_ID to the ID of the folder where files should be uploaded
GOOGLE_DRIVE_FOLDER_ID=""

# Firebase Admin SDK Credentials - Required for external hosting like Render
# Provide the raw JSON string or Base-64 encoded string of your Firebase Service Account JSON
FIREBASE_SERVICE_ACCOUNT=""
FIREBASE_SERVICE_ACCOUNT_BASE64=""
